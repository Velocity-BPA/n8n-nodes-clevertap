  "description": "A comprehensive n8n community node for CleverTap customer engagement platform providing 10 resources and 70+ operations for user profiles, events, campaigns, multi-channel messaging, segments, and analytics.",
  "license": "BUSL-1.1",
  "author": {
    "name": "Velocity BPA",
    "email": "licensing@velobpa.com",
    "url": "https://velobpa.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Velocity-BPA/n8n-nodes-clevertap.git"
  },
  "homepage": "https://github.com/Velocity-BPA/n8n-nodes-clevertap#readme",
  "bugs": {
    "url": "https://github.com/Velocity-BPA/n8n-nodes-clevertap/issues"
  },
  "keywords": [
    "n8n",
    "n8n-community-node-package",
    "clevertap",
    "customer-engagement",
    "marketing-automation",
    "push-notifications",
    "analytics",
    "segmentation",
    "campaigns",
    "mobile-marketing",
    "email-marketing",
    "sms",
    "whatsapp",
    "user-profiles",
    "events",
    "product-catalog"
  ],
  "main": "dist/nodes/CleverTap/CleverTap.node.js",
  "files": [
    "dist",
    "LICENSE",
    "COMMERCIAL_LICENSE.md",
    "LICENSING_FAQ.md",
    "README.md"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/CleverTapApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/CleverTap/CleverTap.node.js"
    ]
  },
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"**/*.ts\"",
    "format:check": "prettier --check \"**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "clean": "rimraf dist",
    "prebuild": "npm run clean",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.19",
    "@typescript-eslint/eslint-plugin": "^7.0.2",
    "@typescript-eslint/parser": "^7.0.2",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.1",
    "gulp": "^4.0.2",
    "jest": "^29.7.0",
    "n8n-workflow": "^1.30.0",
    "prettier": "^3.2.5",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  },
  "peerDependencies": {
    "n8n-workflow": ">=1.0.0"
  }
